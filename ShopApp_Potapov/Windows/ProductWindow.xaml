<Window x:Class="ShopApp_Potapov.Windows.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShopApp_Potapov.Windows"
        mc:Ignorable="d"
        Title="ProductWindow" Height="450" Width="800">


    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Название товара:" 
                           Margin="0,0,0,5" 
                           FontWeight="Bold"
                           Foreground="#2C3E50"/>
                <TextBox x:Name="txtName" 
                         Height="35" 
                         Margin="0,0,0,15" 
                         Padding="8,5"
                         FontSize="14"
                         BorderThickness="1"
                         BorderBrush="#BDC3C7"/>

                <TextBlock Text="Категория:" 
                           Margin="0,0,0,5" 
                           FontWeight="Bold"
                           Foreground="#2C3E50"/>
                <ComboBox x:Name="cmbCategory" 
                          Height="35" 
                          Margin="0,0,0,15" 
                          Padding="5"
                          FontSize="14"/>

                <TextBlock Text="Цена (₽):" 
                           Margin="0,0,0,5" 
                           FontWeight="Bold"
                           Foreground="#2C3E50"/>
                <TextBox x:Name="txtPrice" 
                         Height="35" 
                         Margin="0,0,0,15" 
                         Padding="8,5"
                         FontSize="14"/>

                <TextBlock Text="Количество на складе:" 
                           Margin="0,0,0,5" 
                           FontWeight="Bold"
                           Foreground="#2C3E50"/>
                <TextBox x:Name="txtQuantity" 
                         Height="35" 
                         Margin="0,0,0,15" 
                         Padding="8,5"
                         FontSize="14"/>

                <TextBlock Text="Описание:" 
                           Margin="0,0,0,5" 
                           FontWeight="Bold"
                           Foreground="#2C3E50"/>
                <TextBox x:Name="txtDescription" 
                         Height="100" 
                         Margin="0,0,0,20" 
                         Padding="8,5"
                         FontSize="14"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnSave"
                    Content="Сохранить" 
                    Width="120" 
                    Height="40" 
                    Margin="0,0,10,0" 
                    Click="BtnSave_Click"
                    Background="Green"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="Bold"/>

            <Button x:Name="BtnCancel"
                    Content="Отмена" 
                    Width="120" 
                    Height="40" 
                    Click="BtnCancel_Click"
                    Background="Red"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>

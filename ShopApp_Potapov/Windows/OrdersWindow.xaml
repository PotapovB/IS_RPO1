<Window x:Class="ShopApp_Potapov.Windows.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShopApp_Potapov.Windows"
        mc:Ignorable="d"
        Title="OrdersWindow" Height="450" Width="800">


    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Выберите новый статус:" 
                   FontSize="16" 
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <RadioButton x:Name="rbCreated" 
                         Content="Оформлен" 
                         FontSize="14" 
                         Margin="0,0,0,10"
                         GroupName="StatusGroup"/>

            <RadioButton x:Name="rbShipped" 
                         Content="Отправлен" 
                         FontSize="14" 
                         Margin="0,0,0,10"
                         GroupName="StatusGroup"/>

            <RadioButton x:Name="rbDelivered" 
                         Content="Доставлен" 
                         FontSize="14" 
                         Margin="0,0,0,20"
                         GroupName="StatusGroup"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" 
                    Width="100" 
                    Height="35" 
                    Margin="0,0,10,0" 
                    Click="BtnSave_Click"
                    Background="Green"
                    Foreground="White"
                    FontWeight="Bold"/>

            <Button Content="Отмена" 
                    Width="100" 
                    Height="35" 
                    Click="BtnCancel_Click"
                    Background="Red"
                    Foreground="White"
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>

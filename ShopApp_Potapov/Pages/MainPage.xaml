<Page x:Class="ShopApp_Potapov.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShopApp_Potapov.Pages"
      xmlns:gif="http://wpfanimatedgif.codeplex.com"
      mc:Ignorable="d" 
      Background="White"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="LightCyan" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtAppTitle" 
                           Text="Магазин" 
                           FontSize="20" 
                           FontWeight="Bold"
                           Foreground="bLACK"
                           VerticalAlignment="Center"/>

                <Image gif:ImageBehavior.RepeatBehavior="Forever" gif:ImageBehavior.AnimatedSource="../Images/construction-worker.gif" Height="150"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="txtUserInfo" 
                               Foreground="Black" 
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="DarkCyan" Padding="10">
                <StackPanel x:Name="NavigationMenu">
                    <TextBlock Text="МЕНЮ" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Foreground="#BDC3C7"
                               Margin="0,0,0,15"/>
                    
                </StackPanel>
            </Border>

            <Frame x:Name="MasterFrame" 
                   Grid.Column="1" 
                   NavigationUIVisibility="Hidden"
                   Margin="10"/>
        </Grid>

       
    </Grid>
</Page>

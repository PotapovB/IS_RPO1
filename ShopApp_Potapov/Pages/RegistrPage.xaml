<Page x:Class="ShopApp_Potapov.Pages.RegistrPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShopApp_Potapov.Pages"
      mc:Ignorable="d" 
      Background="White"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegistrPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Регистрация" 
                   FontSize="24" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="ФИО:" Margin="0,0,0,5" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBox x:Name="txtClientFullName" 
                 Height="35" 
                 Margin="0,0,0,15" 
                 Padding="8,5"
                 FontSize="14"/>

                <TextBlock Text="Телефон:" Margin="0,0,0,5" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBox x:Name="txtClientPhone" 
                 Height="35" 
                 Margin="0,0,0,15" 
                 Padding="8,5"
                 FontSize="14"/>

                <TextBlock Text="Email:" Margin="0,0,0,5" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBox x:Name="txtClientEmail" 
                 Height="35" 
                 Margin="0,0,0,20" 
                 Padding="8,5"
                 FontSize="14"/>

                <TextBlock Text="Логин:" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox x:Name="txtLogin" 
                         Height="35" 
                         Margin="0,0,0,15" 
                         Padding="8,5"
                         FontSize="14"/>

                <TextBlock Text="Пароль:" Margin="0,0,0,5" FontWeight="Bold"/>
                <PasswordBox x:Name="txtPassword" 
                             Height="35" 
                             Margin="0,0,0,15" 
                             Padding="8,5"
                             FontSize="14"/>

                <TextBlock Text="Подтвердите пароль:" Margin="0,0,0,5" FontWeight="Bold"/>
                <PasswordBox x:Name="txtPasswordrRep" 
                             Height="35" 
                             Margin="0,0,0,20" 
                             Padding="8,5"
                             FontSize="14"/>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Vertical">
            <Button Content="Зарегистрироваться" 
                    Height="40" 
                    Margin="0,0,0,10" 
                    Click="BtnRegister_Click"
                    Background="Green"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="Bold"/>

            <Button Content="Назад" 
                    Height="40" 
                    Click="BtnBack_Click"
                    Background="Red"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Page>

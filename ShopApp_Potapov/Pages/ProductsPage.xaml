<Page x:Class="ShopApp_Potapov.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShopApp_Potapov.Pages"
      mc:Ignorable="d" 
      Background="White"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductsPage">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnAdd" Content="Добавить" Width="100" Margin="0,0,10,0" Click="BtnAdd_Click"/>
            <Button x:Name="BtnEdit" Content="Редактировать" Width="100" Margin="0,0,10,0" Click="BtnEdit_Click"/>
            <Button x:Name="BtnDelete" Content="Удалить" Width="100" Click="BtnDelete_Click"/>
        </StackPanel>


       

        <DataGrid x:Name="dgProducts" 
                  Grid.Row="2" 
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F5F5F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Categories.Name}" Width="150"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:0.00} ₽}" Width="100"/>
                <DataGridTextColumn Header="Остаток" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="250"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>

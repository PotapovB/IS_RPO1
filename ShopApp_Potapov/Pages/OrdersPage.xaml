<Page x:Class="ShopApp_Potapov.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ShopApp_Potapov.Pages"
      mc:Ignorable="d" 
      Background="White"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OrdersPage">


    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnChangeStatus" Content="Изменить статус" Width="130" Margin="0,0,10,0" Click="BtnChangeStatus_Click"/>
            <ComboBox x:Name="cmbFilterStatus" Width="150" Margin="20,0,0,0" SelectionChanged="cmbFilterStatus_SelectionChanged">
                <ComboBoxItem Content="Все заказы" IsSelected="True"/>
                <ComboBoxItem Content="Оформлен"/>
                <ComboBoxItem Content="Отправлен"/>
                <ComboBoxItem Content="Доставлен"/>
            </ComboBox>
        </StackPanel>

        <DataGrid x:Name="dgOrders" 
                  Grid.Row="1" 
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding Clients.FullName}" Width="150"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding DateCreated, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="120"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Продавец" Binding="{Binding Users.Login}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
